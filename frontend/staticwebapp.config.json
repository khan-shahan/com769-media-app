{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.png", "/*.jpg", "/*.jpeg", "/*.gif", "/*.svg", "/*.css", "/*.js", "/*.map"]
  },
  "routes": [
    {
      "route": "/creator/*",
      "allowedRoles": ["creator"],
      "statusCode": 401,
      "rewrite": "/unauthorized"
    }
  ]
}
